000000r 1               ; Selection Sort for 6502 (Ascending)
000000r 1               ; Data to sort is in 'ARRAY', length is in 'LEN'
000000r 1               ; Uses zero page locations for pointers
000000r 1               
000000r 1               ARRAY   = $0200         ; Start address of data
