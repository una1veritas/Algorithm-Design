00000Er 1  DD 00 02         CMP ARRAY, X        ; Compare current min with Y element
000011r 1  B0 0B            BCS NO_SWAP         ; If ARRAY[X] <= ARRAY[Y], no swap
000013r 1               
000013r 1                   ; Swap elements
