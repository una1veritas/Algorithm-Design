000000r 1               ptr2    = $12
000000r 1               
000000r 1               SORT:
000000r 1  A2 00            LDX #0              ; Outer loop index
000002r 1               OUTER:
000002r 1  86 10            STX ptr1            ; Store outer loop index
000004r 1  8A               TXA
